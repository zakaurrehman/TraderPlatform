# Base URL of the Next.js backend that exposes /api/mobile/* and /api/*.
# Android emulator -> http://10.0.2.2:3000
# iOS simulator    -> http://localhost:3000
# Physical device  -> http://<your-LAN-IP>:3000  (or your deployed https URL)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Optional: your EAS project id (from `eas init`). Used by app.config.ts.
EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000
